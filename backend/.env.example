## DATABASE CONFIGURATION
# Para rodar no Render, obrigatoriamente use a connection string do Pooler do Supabase (para evitar problemas de IPv6/ENETUNREACH).
# IMPORTANTE: O usuário (username) no Pooler deve conter o sufixo do seu projeto no formato: [usuario].[ref_do_projeto]
# Exemplo de ref_do_projeto: hzzujdjgyqnlhtrsfagz (obtido na URL do seu projeto Supabase)

# APP_DATABASE_URL: connection string do Pooler para o usuário limitado da aplicação (com RLS ativo)
# Exemplo: postgresql://fidelidade_app.seu_project_ref:senha@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
APP_DATABASE_URL=postgresql://fidelidade_app.seu_project_ref:senha@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# DATABASE_URL: connection string do Pooler para o usuário postgres/admin (usado para auth/migrations)
# Exemplo: postgresql://postgres.seu_project_ref:senha@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.seu_project_ref:senha@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Fallbacks locais caso DATABASE_URL não seja provido (apenas dev):
DB_HOST=seu-host.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua-senha
DB_NAME=postgres

## PORTA DA APLICACAO (opcional, padrão 3001)
PORT=3001

## AUTH / SECURITY
JWT_SECRET=troque-por-um-segredo-forte
NODE_ENV=production

## SUPABASE CONFIGURATION
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=cole-sua-chave-anon-aqui
SUPABASE_SERVICE_ROLE_KEY=cole-sua-service-role-aqui
SUPABASE_JWT_SECRET=cole-o-jwt-secret-do-supabase-aqui
