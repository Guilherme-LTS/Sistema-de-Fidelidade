DB_HOST=seu-host-postgres
DB_PORT=5432
DB_USER=seu-usuario
DB_PASSWORD=sua-senha
DB_NAME=seu-banco
# Opcional: use DATABASE_URL em vez dos 5 campos acima (ex.: Supabase)
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco
# Use APP_DATABASE_URL para o runtime da aplicação sem BYPASSRLS (host direto do Supabase)
# APP_DATABASE_URL=postgresql://usuario_app:senha@db.seu_project_ref.supabase.co:5432/banco
# Use DATABASE_URL apenas para scripts administrativos/migrations, se necessário
# DATABASE_URL=postgresql://usuario_admin:senha@host:5432/banco
JWT_SECRET=troque-por-um-segredo-forte
NODE_ENV=production
