## DATABASE CONFIGURATION
# Preferencialmente use as connection strings abaixo.
# APP_DATABASE_URL: runtime da aplicação sem BYPASSRLS
# DATABASE_URL: scripts administrativos / migrations
APP_DATABASE_URL=postgresql://usuario_app:senha@db.seu_project_ref.supabase.co:5432/postgres
DATABASE_URL=postgresql://usuario_admin:senha@host:5432/postgres

# Fallbacks caso DATABASE_URL não seja provido:
DB_HOST=seu-host.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua-senha
DB_NAME=postgres

## PORTA DA APLICACAO (opcional, padrão 3001)
PORT=3001

## AUTH / SECURITY
JWT_SECRET=troque-por-um-segredo-forte
NODE_ENV=production

## SUPABASE CONFIGURATION
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=cole-sua-chave-anon-aqui
SUPABASE_SERVICE_ROLE_KEY=cole-sua-service-role-aqui
SUPABASE_JWT_SECRET=cole-o-jwt-secret-do-supabase-aqui
