# === SUPABASE CONFIGURATION ===
# Obtenha essas chaves em: https://app.supabase.com > Settings > API

# Copie de: Settings > API > Project URL

REACT_APP_SUPABASE_URL=

# Copie de: Settings > API > anon public (em azul)
# Esta é a chave "anon" que começa com "eyJ..."
REACT_APP_SUPABASE_ANON_KEY=

# === BACKEND CONFIGURATION ===
REACT_APP_API_URL=

# Tenant padrão para consulta pública de saldo (/public/pontos/:document). Use o UID real do Supabase Auth do restaurante.
REACT_APP_PUBLIC_TENANT_ID=

# Slug público opcional para gerar links diretos no marketing (/p/:tenantSlug)
REACT_APP_PUBLIC_TENANT_SLUG=