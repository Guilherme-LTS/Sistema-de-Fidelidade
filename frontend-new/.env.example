# ==========================================
# SUPABASE CONFIGURAÇÃO PÚBLICA
# ==========================================
# URL do projeto Supabase (Pode ser exposto no cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave pública anon do Supabase (Pode ser exposto no cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ==========================================
# INTEGRAÇÃO BACKEND (API)
# ==========================================
# Endereço base do Backend Fastify. 
# Em dev: http://localhost:4001
# Em prod: https://api-fidelidade.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:4001

# ==========================================
# GOOGLE MAPS API (Opcional - Usado no cadastro de restaurantes)
# ==========================================
# Chave de API pública para renderizar o autocomplete de endereço
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxx

# ==========================================
# OPÇÕES DE DESENVOLVIMENTO
# ==========================================
# Usado apenas para forçar o tenant na página pública de dev
NEXT_PUBLIC_PUBLIC_TENANT_ID=
NEXT_PUBLIC_PUBLIC_TENANT_SLUG=
