# ==========================================
# AMBIENTE DA APLICAÇÃO
# ==========================================
# Opções: development, production, test
NODE_ENV=development
PORT=4001
LOG_LEVEL=info

# ==========================================
# BANCO DE DADOS (Supabase Postgres)
# ==========================================
# Usado pelo Drizzle (conexão Pooling/Transaction)
DATABASE_URL=postgresql://postgres.xxxxx:senha-aqui@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Usado para Migrations (conexão direta - porta 5432)
APP_DATABASE_URL=postgresql://postgres.xxxxx:senha-aqui@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ==========================================
# SUPABASE AUTENTICAÇÃO E API
# ==========================================
# URL do projeto Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave pública anon (pode ser exposta no frontend também)
SUPABASE_ANON_KEY=eyJhbGci...

# Chave privada mestre (NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Secret JWT do projeto (Usado no middleware de validação do token)
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ==========================================
# CORS E COMUNICAÇÃO FRONTEND
# ==========================================
# Lista de origens permitidas (separadas por vírgula). Em dev, use * ou localhost
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# URL do frontend (Usada em templates de e-mail e redirects de senha)
FRONTEND_URL=http://localhost:3000

# ==========================================
# SERVIÇOS EM SEGUNDO PLANO (CRON)
# ==========================================
# Segredo utilizado para validar chamadas do Cronjob (webhook)
CRON_SECRET=minha-chave-secreta-aleatoria-12345
